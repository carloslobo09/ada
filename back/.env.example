# --- Extraccion ---

# Modo del extractor:
#   mock   -> no invoca ningun modelo. Devuelve una respuesta de ejemplo
#             deterministica basada en los campos configurados. Ideal para
#             probar la plataforma completa sin API key ni costo.
#   gemini -> invoca Google Gemini con el documento real. Requiere GEMINI_API_KEY.
EXTRACTOR_MODE=mock

# Requerida solo si EXTRACTOR_MODE=gemini.
#
# Como obtener una API key gratuita:
#   1. Entrar a https://aistudio.google.com con una cuenta de Google.
#   2. Menu "Get API key" -> "Create API key".
#   3. Copiar la key y pegarla aca.
#
# Aviso sobre el tier gratuito: las keys gratuitas comparten capacidad y en
# momentos de alta demanda Google puede devolver errores 429/503 o directamente
# no procesar solicitudes. Si eso pasa, las opciones son reintentar mas tarde,
# volver a EXTRACTOR_MODE=mock, o habilitar facturacion en Google AI Studio
# (el plan prepago con un limite mensual bajo alcanza de sobra para este demo).
GEMINI_API_KEY=

# Modelo de la familia Gemini a invocar. gemini-2.5-flash-lite es el mas
# economico; si esta saturado, probar gemini-2.5-flash o gemini-2.0-flash.
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Almacenamiento ---

DB_URL=sqlite:///./data/ada.db
UPLOAD_DIR=./data/uploads

# --- Observabilidad ---

LOG_LEVEL=INFO

# --- Autenticacion (JWT) ---

# Secreto HS256 para firmar tokens. REGENERAR antes de cualquier deploy.
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=cambiar-este-valor-antes-de-usar-en-cualquier-entorno-real

# Vida del token en minutos.
JWT_EXPIRE_MINUTES=480

# --- Usuarios seed (solo para el demo inicial) ---

# Contrasena que se asigna a los 3 usuarios seed (admin/entrenador/cliente)
# la primera vez que se levanta la app. REGENERAR si esta instancia va a salir
# del entorno local. Cambiar tambien las contrasenas via /auth en cuanto se pueda.
SEED_PASSWORD=ada2026
